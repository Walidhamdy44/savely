generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Supported platforms — only those with accessible saved-content APIs
// youtube: YouTube Data API v3 (liked videos, playlists)
// github: GitHub API v4 (starred repos)
// manual: user-added links (no external API required)
enum Platform {
  youtube
  github
  manual
}

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String   @unique
  username  String?
  imageUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  savedPosts SavedPost[]
  accounts   Account[]
}

// Stores OAuth tokens for connected platforms (encrypted at rest in production)
model Account {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform     Platform
  accessToken  String
  refreshToken String?
  expiresAt    DateTime?
  scope        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([userId, platform])
  @@index([userId])
}

model SavedPost {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform    Platform
  externalId  String
  title       String
  description String?
  url         String
  thumbnail   String?
  metadata    Json?
  savedAt     DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, platform, externalId])
  @@index([userId, platform])
  @@index([userId, savedAt(sort: Desc)])
}
