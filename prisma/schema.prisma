generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String      @id @default(cuid())
  clerkId    String      @unique
  email      String      @unique
  username   String?
  imageUrl   String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  accounts         Account[]
  ApiToken         ApiToken[]
  savedPosts       SavedPost[]
  githubConnection GitHubConnection?
}

model Account {
  id           String    @id @default(cuid())
  userId       String
  platform     Platform
  accessToken  String
  refreshToken String?
  expiresAt    DateTime?
  scope        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, platform])
  @@index([userId])
}

model SavedPost {
  id          String     @id @default(cuid())
  userId      String
  platform    Platform
  externalId  String
  title       String
  description String?
  url         String
  thumbnail   String?
  metadata    Json?
  savedAt     DateTime   @default(now())
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  authorName  String?
  sourceType  SourceType @default(manual)
  note        String?
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  notes       PostNote[]

  @@unique([userId, platform, externalId])
  @@unique([userId, url])
  @@index([userId, platform])
  @@index([userId, savedAt(sort: Desc)])
}

model ApiToken {
  id        String    @id
  userId    String
  name      String
  token     String    @unique
  lastUsed  DateTime?
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  User      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model PostNote {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  post      SavedPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([userId])
}

model GitHubConnection {
  id        String   @id @default(cuid())
  userId    String   @unique
  username  String
  avatarUrl String?
  bio       String?
  location  String?
  publicRepos Int    @default(0)
  followers   Int    @default(0)
  following   Int    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum Platform {
  youtube
  github
  manual
  linkedin
  instagram
}

enum SourceType {
  manual
  extension
  youtube_liked
  github_starred
}
